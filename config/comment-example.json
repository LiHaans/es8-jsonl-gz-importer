{
  "jobName": "comment",
  "inputDir": "/data/comment_data",
  "indexName": "comment_index",
  "esHosts": ["http://127.0.0.1:9200"],
  "idField": "comment_id",
  "routingField": "user_id",
  "fileParallelism": 3,
  "writerParallelism": 6,
  "batchDocLimit": 3000,
  "batchBytesLimit": 8388608,
  "queueCapacity": 200,
  "maxRetries": 5,
  "retryBaseMillis": 1000,
  "checkpointDbPath": "./runtime/comment-checkpoints.db",
  "deadLetterDir": "./runtime/deadletter",
  "checkpointFlushEveryLines": 1000,
  "metricsLogIntervalSeconds": 15
}
